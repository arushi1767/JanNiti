# ============================================================
#  JanNiti backend — environment configuration
#  This build uses OpenAI ONLY (one key powers chat + voice).
# ============================================================

# ---- LLM provider ----
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

LLM_TIMEOUT=60
LLM_MAX_TOKENS=1024

# ---- RAG / data ----
CHROMA_PERSIST_DIR=./data/chroma
EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
AUTO_INGEST_ON_START=true

# ---- research flags ----
ENABLE_FAITHFULNESS=true
ENABLE_SELECTIVE_RETRIEVAL=true

# ---- CORS (comma-separated; add your deployed frontend URL after you deploy it) ----
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend.vercel.app

# ---- optional ----
DATAGOV_API_KEY=
